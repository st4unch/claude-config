{
  "permissions": {
    "allow": [
      "mcp__pencil"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cmd=$(jq -r '.tool_input.command // \"\"'); if echo \"$cmd\" | grep -qE 'rm[[:space:]]+-[a-zA-Z]*f|rm[[:space:]]+-rf'; then echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"ask\",\"permissionDecisionReason\":\"Bu komut rm -f veya rm -rf iceriyor ve dosyalari kalici olarak silebilir!\"}}'; fi",
            "statusMessage": "rm -f komutu kontrol ediliyor..."
          }
        ]
      },
      {
        "matcher": "Read|Write|Edit|Glob|Grep|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/sandbox-guard.sh",
            "statusMessage": "Dizin erisim kontrolu..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/telegram-notify.sh",
            "statusMessage": "Telegram bildirimi gonderiliyor..."
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "supabase@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "figma@claude-plugins-official": true,
    "telegram@claude-plugins-official": true
  },
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true
}
