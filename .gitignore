# Ignore everything by default
*

# Track config files
!.gitignore
!README.md
!CLAUDE.md
!settings.json
!keybindings.json
!sync.sh

# Track commands (switch, etc.)
!commands/
!commands/**

# Track hooks
!hooks/
!hooks/**

# Track scripts
!scripts/
!scripts/**

# Track skills
!skills/
!skills/**

# Explicit denies (belt-and-suspenders — never leak via sync)
projects/
tasks/
channels/
approvals/
.env
.env.*

# Sensitive file patterns (defense in depth)
**/reference_*credentials*.md
**/reference_*secret*.md
**/reference_*token*.md
**/reference_*password*.md

# Machine-specific - do NOT track
settings.local.json
settings.json_zai
remote-settings.json
*.local.json
